# .env.example — CI/CD and deploy environment variables
# Copy to .env (never commit .env — it is in .gitignore)

# ── Deploy target (GitHub Actions / GitLab CI secrets) ─────────────────
SSH_HOST=your-vm-ip
SSH_USER=gcvmuser
DEPLOY_DIR=/home/gcvmuser/MISEIA_1-6-10-revproxy-c

# ── Docker / Traefik ────────────────────────────────────────────────────
DOMAIN=your-domain.com
TRAEFIK_NETWORK=miseia-net

# ── Cloudflare (for Traefik DNS-01 wildcard TLS) ────────────────────────
CF_DNS_API_TOKEN=your-cloudflare-dns-api-token
CF_API_TOKEN=your-cloudflare-api-token

# ── GCP (optional, for gcloud-based secrets) ────────────────────────────
GCP_PROJECT=your-gcp-project-id
GCP_ZONE=your-gcp-zone
VM_NAME=your-vm-name
